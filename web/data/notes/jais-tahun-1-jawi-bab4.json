            "intro": "Cuba baca dan tulis perkataan-perkataan ini:",
            "items": [
              "سوتوغ — sotong",
              "جوغكوغ — jongkong",
              "چوندوغ — condong",
              "دودوق — duduk",
              "كبون — kebun",
              "بوندا — bonda"
            ],
            "outro": "Perhatikan: ng = غ dan c = چ"
          }
        }
      ]
