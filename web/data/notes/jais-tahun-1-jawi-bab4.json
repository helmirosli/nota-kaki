      "type": "concept-cards",
      "items": [
        {
          "icon": "🔤",
          "title": "Konsonan Kumpulan Pertama",
          "body": {
            "type": "list",
            "intro": "Padanan konsonan Kumpulan Pertama:",
            "items": [
              "b = ب (ba)",
              "t = ت (ta)",
              "j = ج (jim)",
              "c = چ (ca)",
              "ng = غ (nga)"
            ],
            "outro": "Contoh: جال (jala) • ليماو (limau) • مادو (madu)"
          }
        },
        {
          "icon": "🔤",
          "title": "Konsonan Kumpulan Kedua",
          "body": {
            "type": "list",
            "intro": "Padanan konsonan Kumpulan Kedua:",
            "items": [
              "d = د (dal)",
              "r = ر (ro)",
              "s = س (sin) atau ص (sod)",
              "l = ل (lam)",
              "m = م (mim)",
              "n = ن (nun)"
            ],
            "outro": "Contoh: ناسي (nasi) • ڤادي (padi) • روتي (roti)"
          }
        },
        {
          "icon": "⚠️",
          "title": "Huruf 's' Ada Dua Padanan!",
          "body": {
            "type": "list",
            "intro": "Konsonan 's' boleh ditulis dengan dua cara dalam Jawi:",
            "items": [
              "س (sin) — untuk kata Melayu biasa. Contoh: ساتو (satu), سيني (sini)",
              "ص (sod) — untuk kata dari bahasa Arab. Contoh: صلاة (solat), صبر (sabar)"
            ],
            "outro": "Perlu hafal setiap perkataan kerana tiada peraturan tetap!"
          }
        },
        {
          "icon": "🏋️",
