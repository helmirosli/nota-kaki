          "icon": "➕",
          "title": "Awalan me- dalam Jawi",
          "body": {
            "type": "arabic",
            "instruction": "Awalan me- ditulis م di depan kata dasar. Contoh:",
            "arabic": "م + باچ = مباچ",
            "translation": "me + baca = membaca",
            "more": [
              {
                "arabic": "م + توليس = منوليس",
                "translation": "me + tulis = menulis"
              },
              {
                "arabic": "م + ماکن = مماکن",
                "translation": "me + makan = memakan"
              },
              {
                "arabic": "م + جومڤ = منجومڤ",
                "translation": "me + jumpa = menjumpa"
              }
            ]
          }
        },
        {
          "icon": "🔗",
          "title": "Awalan ber- dalam Jawi",
          "body": {
            "type": "arabic",
            "instruction": "Awalan ber- ditulis بر di depan kata dasar. Contoh:",
            "arabic": "بر + جالن = برجالن",
            "translation": "ber + jalan = berjalan",
            "more": [
              {
                "arabic": "بر + دوع = بردوع",
                "translation": "ber + doa = berdoa"
              },
              {
                "arabic": "بر + صولت = برصولت",
                "translation": "ber + solat = bersolat"
              },
              {
                "arabic": "بر + ماين = برماين",
                "translation": "ber + main = bermain"
              }
            ]
          }
        },
        {
          "icon": "📝",
          "title": "Akhiran -kan dan -an dalam Jawi",
          "body": {
            "type": "arabic",
            "instruction": "Akhiran -kan ditulis کن di belakang kata dasar:",
            "arabic": "باچ + کن = باچکن",
            "translation": "baca + kan = bacakan",
            "more": [
              {
                "arabic": "توليس + کن = توليسکن",
                "translation": "tulis + kan = tuliskan"
              },
              {
                "instruction": "Akhiran -an ditulis ن di belakang:",
                "arabic": "توليس + ن = توليسن",
                "translation": "tulis + an = tulisan"
              },
              {
                "arabic": "ماکن + ن = ماکانن",
                "translation": "makan + an = makanan"
              }
            ]
          }
        },
        {
          "icon": "⚡",
          "title": "Awalan ter- dan pe- dalam Jawi",
          "body": {
            "type": "arabic",
            "instruction": "Awalan ter- ditulis تر di depan kata dasar:",
            "arabic": "تر + باچ = تربچ",
            "translation": "ter + baca = terbaca",
            "more": [
              {
                "arabic": "تر + لوڤ = ترلوڤ",
                "translation": "ter + lupa = terlupa"
              },
              {
                "instruction": "Awalan pe- ditulis ڤ di depan:",
                "arabic": "ڤ + لاجر = ڤلاجر",
                "translation": "pe + lajar = pelajar"
              },
              {
                "arabic": "ڤ + نوليس = ڤنوليس",
                "translation": "pe + nulis = penulis"
              }
            ]
          }
        }
